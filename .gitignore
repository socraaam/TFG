# Repositorio público: solo se versionan Datasets/, Scripts/, README.md
# y requirements.txt. Todo lo demás (TFG_LaTeX/, resultados/, legacy/, etc.)
# se queda en local.
/*
!/Datasets/
!/Scripts/
!/README.md
!/requirements.txt
!/.gitignore
!/.gitattributes

# Cachés de Python dentro de Scripts/
Scripts/**/__pycache__/
Scripts/**/*.py[cod]
